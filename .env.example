# CTRLpanel Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is gitignored).
# For production (Cloudflare), set the same values as Worker secrets:
#   npx wrangler secret put <NAME>

# ── Supabase ────────────────────────────────────────────────
# Supabase → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# service_role SECRET key (same Settings → API page).
# Backend-only — bypasses Row-Level Security. Required for:
#   - Google Calendar OAuth (google_tokens is service-role-only by design)
#   - headless agents writing agent_runs
# Never expose it to the frontend or commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-here

# ── Anthropic Claude API ────────────────────────────────────
# console.anthropic.com → API Keys. Optional if every user supplies their own
# key via Settings → Connectors (per-user keys take precedence).
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Google Calendar OAuth ───────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web)
# Authorized redirect URIs must include the value of GOOGLE_REDIRECT_URI below
# (register both your local and production URLs on the OAuth client).
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local dev:   http://localhost:3001/api/calendar/callback
# Production:  https://your-domain/api/calendar/callback
GOOGLE_REDIRECT_URI=http://localhost:3001/api/calendar/callback

# ── Stock prices (optional) ─────────────────────────────────
# alphavantage.co free API key. Without it, stock/ETF prices fall back to
# deterministic mock values (crypto always uses CoinGecko, no key needed).
ALPHA_VANTAGE_KEY=

# ── Local dev server ────────────────────────────────────────
PORT=3001
# SPA origin, used for CORS + post-OAuth redirects.
# Local dev: http://localhost:5173 · Production: https://your-domain
FRONTEND_URL=http://localhost:5173
